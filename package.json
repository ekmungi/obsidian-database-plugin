    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "jsdom": "^24.0.0",
    "obsidian": "latest",
    "preact": "^10.19.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "@vitest/coverage-v8": "^1.2.0"
  },
  "dependencies": {
    "preact": "^10.19.0"
  }
